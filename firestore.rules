rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Users ---
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // --- Trips ---
    match /trips/{tripId} {
      
      // Helper: ¿Es participante?
      function isParticipant() {
        return exists(/databases/$(database)/documents/trips/$(tripId)/participants/$(request.auth.uid));
      }
      
      // Helper: Retorna el rol del usuario actual
      function myRole() {
        return get(/databases/$(database)/documents/trips/$(tripId)/participants/$(request.auth.uid)).data.role;
      }
      
      // Helper: Retorna los customPermissions del usuario actual
      function myOverrides() {
        let pData = get(/databases/$(database)/documents/trips/$(tripId)/participants/$(request.auth.uid)).data;
        return pData.keys().hasAll(['customPermissions']) ? pData.customPermissions : {};
      }

      // Helper: ¿Es admin o owner?
      function isAdminOrOwner() {
        let role = myRole();
        return role == 'admin' || role == 'owner';
      }

      // Helper: Verifica un permiso general mediante RBAC
      function hasPermission(permissionName, defaultRoles) {
        let role = myRole();
        if (role == 'owner') return true;
        
        let overrides = myOverrides();
        let hasOverride = overrides.keys().hasAll([permissionName]);
        
        if (hasOverride) {
          return overrides[permissionName] == true;
        }
        
        return role in defaultRoles;
      }

      // Helper: ¿Está archivado?
      function isArchived() {
        return resource.data.status == 'archived';
      }

      // El Viaje en sí
      allow read: if isParticipant();
      allow create: if request.auth != null;
      // Actualizar si es admin/owner y el viaje no está archivado
      allow update: if isAdminOrOwner() && !isArchived();
      allow delete: if false; // Los viajes se archivan, no se eliminan

      // --- Participants ---
      match /participants/{participantId} {
        allow read: if isParticipant();
        // Solo Admin/Owner puede invitar/crear o actualizar roles
        allow create: if isAdminOrOwner();
        allow update: if isAdminOrOwner() && !isArchived();
        allow delete: if isAdminOrOwner() && !isArchived();
      }

      // --- Content Subcollections ---
      
      // proposals
      match /{subcollection}/{docId} {
        // Validación aplicable a modules que terminen en _proposals
        // o colecciones iterativas abiertas a collaborators.
        allow read: if isParticipant();
        allow create: if isParticipant() && !isArchived();
        // Para update, el RBAC completo es resuelto mayoritariamente en el Front 
        // y con reglas base de ownership aquí, o permisos extendidos.
        // Simplificado al MVP: Members en un active trip pueden opinar/votar.
        allow update: if isParticipant() && !isArchived();
        allow delete: if isParticipant() && !isArchived();
      }
    }
  }
}
